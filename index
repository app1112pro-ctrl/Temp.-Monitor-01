// โหลด History ตามช่วงวันที่เลือก
async function loadHistByDate() {
  const fromEl = document.getElementById('hist-date-from');
  const toEl   = document.getElementById('hist-date-to');
  if (!fromEl || !toEl || !fromEl.value || !toEl.value) {
    showToast('กรุณาเลือกวันเริ่มต้นและวันสิ้นสุด','warn');
    return;
  }
  const fromDate = fromEl.value;
  const toDate   = toEl.value;
  if (fromDate > toDate) { showToast('วันเริ่มต้นต้องน้อยกว่าวันสิ้นสุด','warn'); return; }

  $('hist-status').textContent = 'กำลังโหลดช่วง ' + fromDate + ' ถึง ' + toDate + '...';

  if (!CFG.sheetsUrl || CFG.sheetsUrl.includes('YOUR_')) {
    $('hist-status').textContent = 'ยังไม่ตั้งค่า sheetsUrl';
    return;
  }
  try {
    const res  = await fetch(CFG.sheetsUrl);
    const text = await res.text();
    const lines = text.trim().split('\n');
    if (lines.length < 2) return;
    const hdrs  = lines[0].split(',').map(h => h.replace(/^"|"$/g,'').trim().toLowerCase());
    const iTime = hdrs.indexOf('time');
    const iAir  = hdrs.indexOf('temp_air');
    const iHumi = hdrs.indexOf('humidity');
    const iProd = hdrs.indexOf('temp_product');
    const iFan  = hdrs.indexOf('fan');
    const iProg = hdrs.indexOf('program');
    const iState= hdrs.indexOf('sys_state');
    const rows  = [];
    for (let i=1; i<lines.length; i++) {
      if (!lines[i].trim()) continue;
      const cols = lines[i].split(',').map(c => c.replace(/^"|"$/g,'').trim());
      const ts   = cols[iTime];
      if (!ts) continue;
      const dateOnly = ts.slice(0,10);
      if (dateOnly < fromDate || dateOnly > toDate) continue;
      const dt = new Date(ts.replace(' ','T'));
      if (isNaN(dt)) continue;
      rows.push({
        ts: dt, time: dt.toLocaleString('th-TH'),
        air:  parseFloat(cols[iAir])  || null,
        humi: parseFloat(cols[iHumi]) || null,
        prod: parseFloat(cols[iProd]) || null,
        fan:  (cols[iFan]  || '').toUpperCase(),
        prog: cols[iProg]  || '',
        state:cols[iState] || '',
      });
    }
    if (!rows.length) { $('hist-status').textContent = 'ไม่มีข้อมูลในช่วงที่เลือก'; return; }
    renderHistCharts(rows);
    renderHistTable(rows.slice(-30).reverse());
    renderHistStats(rows);
    $('hist-status').textContent = 'โหลดสำเร็จ ' + rows.length + ' จุด · ' + fromDate + ' ถึง ' + toDate;
  } catch(e) {
    $('hist-status').textContent = 'โหลดไม่สำเร็จ: ' + e.message;
  }
}

