function updateCompare() {
  // v2.6.1 Fix: ใช้ !== null แทน truthy check
  if (state.air === null || weatherState.temp === null) return;
  const maxT = Math.max(state.air, weatherState.temp, 50);
  const inW  = Math.min((state.air / maxT) * 100, 100).toFixed(0);
  const outW = Math.min((weatherState.temp / maxT) * 100, 100).toFixed(0);
  $('cmp-air-bar').style.width = inW + '%';
  $('cmp-w-bar').style.width   = outW + '%';
  $('cmp-temp-val').textContent = state.air.toFixed(1) + '°  /  ' + weatherState.temp + '°C';

  if (state.humi === null) return; // v2.6.1 Fix
  const maxH = Math.max(state.humi, weatherState.humi, 100);
  $('cmp-humi-in').style.width  = ((state.humi / maxH)*100).toFixed(0) + '%';
  $('cmp-humi-out').style.width = ((weatherState.humi / maxH)*100).toFixed(0) + '%';
  $('cmp-humi-val').textContent = state.humi.toFixed(0) + '%  /  ' + weatherState.humi + '%';
}

