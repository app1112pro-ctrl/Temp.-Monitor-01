  } else {
    pauseChartUpdates = false;
    logMqtt('[Visibility] กลับมาดูหน้าจอ — sync ข้อมูล', '#34d399');
    // v2.5.1: delay 1s ให้ browser stabilize ก่อน fetch
    setTimeout(() => {
      if (rtChart) loadTodayIntoRtChart(); // มี retry อัตโนมัติ
    }, 1000);
    // reconnect MQTT ถ้าหลุด
    if (!mqttClient || mqttClient.disconnected) {
      mqttReconnectDelay = 5000;
      setTimeout(() => connectMQTT(), 1500); // delay ก่อน reconnect ด้วย
    }
  }
});

connectMQTT();
fetchWeather();
setInterval(fetchWeather, 300000);
// โหลดข้อมูลวันนี้จาก Sheets มาเติม RT chart slots
setTimeout(loadTodayIntoRtChart, 2000); // refresh weather ทุก 5 นาที
// v2.6.2: อัปเดต metric cards จาก Sheets ทุก 10 นาที (ตรงกับ ESP32 log interval)
setInterval(updateLatestStateFromSheets, 600000);

</script>
</body>
</html>
