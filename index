function drawRtEndLabels() {
  if (!rtChart) return;
  const datasets = [
    { data: rtAllData.air,  color: '#60a5fa', axis: 'yT', label:'T.อากาศ' },
    { data: rtAllData.humi, color: '#34d399', axis: 'yH', label:'ความชื้น' },
    { data: rtAllData.prod, color: '#fb923c', axis: 'yT', label:'T.ผลิต' },
  ];
  const ctx = rtChart.ctx;
  const ca  = rtChart.chartArea;
  if (!ca) return;
  ctx.save();

  // เก็บ y positions เพื่อตรวจ overlap
  const placed = []; // [{y, side}]
  const MIN_GAP = 14; // px ขั้นต่ำระหว่าง label

  datasets.forEach(ds => {
    try {
      const lastIdx = lastFilledIdx(ds.data);
      if (lastIdx < 0) return;
      const val    = ds.data[lastIdx];
      if (val === null || isNaN(val)) return;
      const xScale = rtChart.scales && rtChart.scales.x;
      const yScale = rtChart.scales && rtChart.scales[ds.axis];
      if (!xScale || !yScale) return;
      const x  = xScale.getPixelForValue(lastIdx);
      let   y  = yScale.getPixelForValue(val);

      // ปรับ y ถ้า overlap
      let adjusted = y;
      placed.forEach(p => {
        if (Math.abs(adjusted - p.y) < MIN_GAP) {
          adjusted = p.y + (adjusted >= p.y ? MIN_GAP : -MIN_GAP);
        }
      });
      placed.push({ y: adjusted });

      // วงกลม ที่ตำแหน่งจริง
      ctx.beginPath();
      ctx.arc(x, y, 5, 0, Math.PI*2);
      ctx.fillStyle = ds.color;
      ctx.fill();
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // ตัวเลข ที่ตำแหน่งปรับแล้ว
      const isRight = x > ca.right - 70;
      ctx.fillStyle = ds.color;
      ctx.font = 'bold 11px IBM Plex Mono, monospace';
      ctx.textAlign = isRight ? 'right' : 'left';
      ctx.textBaseline = 'middle';
      const offsetX = isRight ? -10 : 10;
      ctx.fillText(val.toFixed(1), x + offsetX, adjusted);

      // เส้นเชื่อม ถ้า adjusted ≠ y
      if (Math.abs(adjusted - y) > 2) {
        ctx.beginPath();
        ctx.strokeStyle = ds.color + '80';
        ctx.lineWidth = 0.8;
        ctx.setLineDash([2,2]);
        ctx.moveTo(x + (isRight ? -6 : 6), y);
        ctx.lineTo(x + offsetX, adjusted);
        ctx.stroke();
        ctx.setLineDash([]);
      }
    } catch(e) {}
  });
  ctx.restore();
}

