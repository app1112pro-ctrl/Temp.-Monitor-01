let rtChart;
let rtAllData = { labels:[], air:[], humi:[], prod:[] }; // เก็บข้อมูล 24 ชม.

function buildRtLabels() {
  // ทุก 10 นาที = 144 slots ต่อวัน
  const labs = [];
  for (let h=0; h<24; h++) {
    for (let m=0; m<60; m+=10) {
      labs.push(String(h).padStart(2,'0')+':'+String(m).padStart(2,'0'));
    }
  }
  return labs; // 144 slots
}

function slotIndex(dateObj) {
  // slot ทุก 10 นาที (0-143)
  return dateObj.getHours()*6 + Math.floor(dateObj.getMinutes()/10);
}

function initRtChart() {
