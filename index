<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SQUID_DRY 2026 V.0.0.1 | Ink Drying Monitor</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mqtt/5.3.4/mqtt.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');

  :root {
    --bg:       #0b0f1a;
    --bg2:      #111827;
    --bg3:      #1a2235;
    --border:   #1e2d45;
    --text:     #c8d8f0;
    --muted:    #5a7090;
    --air:      #60a5fa;
    --humi:     #34d399;
    --prod:     #fbbf24;
    --night:    #a78bfa;
    --rain:     #22d3ee;
    --over:     #fb923c;
    --danger:   #f87171;
    --success:  #34d399;
    --font:     'IBM Plex Sans Thai', sans-serif;
    --mono:     'IBM Plex Mono', monospace;
  }
  body.light {
    --bg:      #f1f5f9; --bg2:     #ffffff; --bg3:    #f8fafc;
    --border:  #cbd5e1; --text:    #1e293b; --muted:  #475569;
    --air:     #1d4ed8; --humi:    #15803d; --prod:   #a16207;
    --night:   #7c3aed; --rain:    #0891b2; --over:   #c2410c;
    --danger:  #dc2626; --success: #16a34a;
  }
  body.light .header-title { color:#1e293b !important; }
  body.light .tab.active   { background:#dbeafe; border-color:#93c5fd; color:#1d4ed8; }
  body.light .tab          { color:#475569; }
  body.light .tab:hover    { background:#e2e8f0; color:#1e293b; }
  body.light .mqtt-log     { background:#f1f5f9; color:#475569; }
  body.light .conn-pill    { background:#ffffff; }
  body.light .alert-ok     { background:#f0fdf4; border-color:#16a34a; color:#15803d; }
  body.light .alert-warn   { background:#fefce8; border-color:#ca8a04; color:#a16207; }
  body.light .alert-err    { background:#fef2f2; border-color:#dc2626; color:#dc2626; }
  body.light .alert-rain   { background:#ecfeff; border-color:#0891b2; color:#0e7490; }
  body.light .alert-night  { background:#f5f3ff; border-color:#7c3aed; color:#6d28d9; }
  .theme-toggle {
    width:38px; height:22px; border-radius:11px; border:1.5px solid var(--border);
    background:var(--bg3); cursor:pointer; position:relative; transition:background .25s;
    flex-shrink:0; outline:none;
  }

  .font-btn {
    display:flex; align-items:center; gap:2px;
  }
  .font-btn button {
    background:var(--bg3); border:1px solid var(--border); border-radius:5px;
    color:var(--muted); cursor:pointer; font-family:var(--font);
    padding:2px 7px; font-size:11px; transition:all .15s; line-height:1.4;
  }
  .font-btn button:hover  { color:var(--text); border-color:var(--air); }
  .font-btn button.active { color:var(--air);  border-color:var(--air); background:var(--bg2); }
  .theme-toggle::after {
    content:''; position:absolute; top:3px; left:3px;
    width:14px; height:14px; border-radius:50%;
    background:var(--muted); transition:transform .25s, background .25s;
  }
  body.light .theme-toggle { background:#dbeafe; border-color:#93c5fd; }
  body.light .theme-toggle::after { transform:translateX(16px); background:#1d4ed8; }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    min-height: 100vh;
  }
  body.font-sm  { font-size: 12px !important; }
  body.font-sm * { font-size: inherit; }
  body.font-md  { font-size: 14px !important; }
  body.font-md * { font-size: inherit; }
  body.font-lg  { font-size: 17px !important; }
  body.font-lg * { font-size: inherit; }

  /* ── Layout ─────────────────────────────── */
  .shell { max-width: 1100px; margin: 0 auto; padding: 0 16px 40px; }

  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 0 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
    gap: 12px; overflow: hidden;
  }
  .header-left { display: flex; align-items: center; gap: 14px; }
  .logo-mark {
    width: 36px; height: 36px; border-radius: 8px;
    background: linear-gradient(135deg,#1a3a5c,#0d2035);
    border: 1px solid #1e4070;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono); font-size: 11px; color: var(--air); font-weight: 500;
  }
  .header-title { font-size: 16px; font-weight: 600; color: var(--text); letter-spacing: -.01em; }
  .header-sub { font-size: 11px; color: var(--muted); margin-top: 1px; }
  .conn-pill {
    display: flex; align-items: center; gap: 6px;
    padding: 5px 12px; border-radius: 20px;
    background: var(--bg2); border: 1px solid var(--border);
    font-size: 11px; color: var(--muted);
  }
  .conn-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--muted); }
  .conn-dot.on { background: var(--success); box-shadow: 0 0 6px var(--success); }
  .conn-dot.err { background: var(--danger); }

  /* ── Nav Tabs ────────────────────────────── */
  .tabs { display: flex; gap: 4px; margin-bottom: 20px; }
  .tab {
    padding: 7px 16px; border-radius: 6px; font-size: 13px; font-weight: 500;
    cursor: pointer; color: var(--muted);
    background: transparent; border: 1px solid transparent;
    transition: all .15s;
  }
  .tab:hover { color: var(--text); background: var(--bg2); }
  .tab.active { color: var(--air); background: #0d2035; border-color: #1e4070; }

  /* ── Cards ──────────────────────────────── */
  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px;
  }
  .card-title {
    font-size: 10px; font-weight: 500; letter-spacing: .1em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 12px;
  }

  /* ── Metric grid ────────────────────────── */
  .metric-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 14px; }
  .metric-card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 10px; padding: 18px 12px; text-align: center;
  }
  .metric-label { font-size: 11px; font-weight: 500; color: var(--muted); letter-spacing: .05em; text-transform: uppercase; margin-bottom: 8px; }
  .metric-val { font-family: var(--mono); font-size: clamp(26px, 2.8vw, 42px); font-weight: 800; line-height: 1; letter-spacing: -0.5px; }
  .metric-unit { font-size: 13px; font-weight: 500; color: var(--muted); margin-top: 6px; }
  .metric-delta { font-size: 10px; margin-top: 4px; }

  /* ── Status row ─────────────────────────── */
  .status-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 14px; }
  .status-card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 12px;
  }
  .status-label { font-size: 9px; color: var(--muted); letter-spacing: .06em; text-transform: uppercase; margin-bottom: 4px; }
  .status-val { font-size: 13px; font-weight: 500; }

  /* ── Alert banner ───────────────────────── */
  .alert-banner {
    border-radius: 8px; padding: 10px 14px; margin-bottom: 14px;
    border-left: 3px solid; font-size: 12.5px; line-height: 1.5;
    display: flex; align-items: center; gap: 10px;
  }
  .alert-ok   { background: #0a1f14; border-color: var(--success); color: #6ee7b7; }
  .alert-warn { background: #1a1200; border-color: var(--prod);    color: #fcd34d; }
  .alert-err  { background: #1a0a0a; border-color: var(--danger);  color: #fca5a5; }
  .alert-rain { background: #041618; border-color: var(--rain);    color: var(--rain); }
  .alert-night{ background: #120e1f; border-color: var(--night);   color: var(--night);}

  /* ── Progress bars ──────────────────────── */
  .bar-section { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
  .bar-item { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; }
  .bar-top { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-bottom: 7px; }
  .bar-top b { color: var(--text); }
  .bar-track { background: var(--bg); border-radius: 4px; height: 7px; overflow: hidden; }
  .bar-fill  { height: 100%; border-radius: 4px; transition: width .6s ease; }

  /* ── Weather sidebar ────────────────────── */
  .main-grid { display: grid; grid-template-columns: 1fr 280px; gap: 14px; }
  .weather-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 14px; overflow: hidden; word-break: break-word; }
  .weather-big { font-family: var(--mono); font-size: clamp(32px, 3.5vw, 52px); font-weight: 800; color: var(--air); line-height: 1; margin: 6px 0 2px; letter-spacing:-1px; }
  .weather-row { display: flex; justify-content: space-between; font-size: 12px; color: var(--muted); padding: 5px 0; border-bottom: 1px solid var(--border); }
  .weather-row:last-child { border-bottom: none; }
  .weather-row b { color: var(--text); font-weight: 500; }
  .weather-compare { margin-top: 12px; }
  .cmp-row { display: flex; flex-direction: column; gap: 3px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 12px; }
  .cmp-row:last-child { border-bottom: none; }
  .cmp-label { color: var(--muted); font-size:11px; line-height:1.3; }
  .cmp-bar-wrap { display: flex; gap: 4px; align-items: center; flex: 1; }
  .cmp-bar { height: 5px; border-radius: 3px; }
  .cmp-val { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--text); white-space: nowrap; }

  /* ── Program buttons ────────────────────── */
  .prog-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 8px; margin-bottom: 14px; }
  .prog-btn {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 14px; cursor: pointer;
    text-align: left; transition: all .15s; color: var(--text);
    font-family: var(--font);
  }
  .prog-btn:hover { border-color: #2a4a7a; background: #131e30; }
  .prog-btn.active { border-color: var(--air); background: #0d2035; }
  .prog-btn.disabled { opacity: .4; cursor: not-allowed; }
  .prog-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .prog-meta { font-size: 11px; color: var(--muted); line-height: 1.6; }
  .prog-badge { display: inline-block; font-size: 9px; padding: 1px 6px; border-radius: 3px; font-weight: 500; margin-left: 6px; }

  .fan-ctrl { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: 14px; }
  .ctrl-btn {
    padding: 10px; border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 500;
    border: 1px solid var(--border); background: var(--bg3); color: var(--text);
    font-family: var(--font); transition: all .15s;
  }
  .ctrl-btn:hover { opacity: .85; }
  .ctrl-btn.green { border-color: #166534; background: #052e16; color: #86efac; }
  .ctrl-btn.red   { border-color: #991b1b; background: #2d0a0a; color: #fca5a5; }
  .ctrl-btn.blue  { border-color: #1e3a5f; background: #0c1e35; color: #93c5fd; }
  .ctrl-btn.disabled { opacity: .35; cursor: not-allowed; }

  .night-ctrl { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px; }
  .night-ctrl label { font-size: 11px; color: var(--muted); display: block; margin-bottom: 4px; }
  .night-ctrl input {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    padding: 7px 10px; color: var(--text); font-family: var(--mono); font-size: 13px;
    width: 100%; outline: none;
  }
  .night-ctrl input:focus { border-color: #2a4a7a; }
  .send-btn {
    width: 100%; padding: 10px; border-radius: 8px; cursor: pointer;
    font-size: 13px; font-weight: 500; font-family: var(--font);
    border: 1px solid #1e4070; background: #0d2035; color: var(--air);
    transition: all .15s;
  }
  .send-btn:hover { background: #122840; }
  .send-btn:disabled { opacity: .4; cursor: not-allowed; }

  /* ── History tab ─────────────────────────── */
  .hist-filter { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
  .filter-btn {
    padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 500;
    cursor: pointer; border: 1px solid var(--border); background: var(--bg3); color: var(--muted);
    font-family: var(--font); transition: all .15s;
  }
  .filter-btn.active { border-color: var(--air); background: #0d2035; color: var(--air); }
  .hist-chart-wrap { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; margin-bottom: 14px; }
  .chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  canvas { max-height: 200px; }

  /* ── Log table ──────────────────────────── */
  .log-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .log-table th { font-size: 10px; color: var(--muted); letter-spacing: .06em; text-transform: uppercase; padding: 6px 10px; text-align: left; border-bottom: 1px solid var(--border); }
  .log-table td { padding: 7px 10px; border-bottom: 1px solid var(--border); font-family: var(--mono); font-size: 11.5px; }
  .log-table tr:last-child td { border-bottom: none; }
  .log-table tr:hover td { background: var(--bg3); }

  /* ── MQTT log ───────────────────────────── */
  .mqtt-log { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; font-family: var(--mono); font-size: 10.5px; color: var(--muted); height: 100px; overflow-y: auto; line-height: 1.6; }

  /* ── Page sections ──────────────────────── */
  .page { display: none; }
  .page.active { display: block; }

  /* ── Responsive ─────────────────────────── */
  @media (max-width: 700px) {
    .main-grid { grid-template-columns: 1fr; }
    .metric-grid { grid-template-columns: 1fr 1fr; }
    .status-row { grid-template-columns: 1fr 1fr; }
    .chart-row { grid-template-columns: 1fr; }
  }

  .lang-btn {
    background:var(--bg3); border:1px solid var(--border); border-radius:5px;
    color:var(--muted); cursor:pointer; font-family:var(--font);
    padding:3px 9px; font-size:11.5px; font-weight:500; transition:all .15s;
  }
  .lang-btn:hover  { color:var(--text); border-color:var(--air); }
  .lang-btn.active { color:var(--air);  border-color:var(--air); background:var(--bg2); }

  .date-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 0 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 14px;
    flex-wrap: wrap; gap: 8px;
  }
  .date-left { display: flex; flex-direction: column; gap: 2px; }
  .date-weekday-big {
    font-size: clamp(22px, 3.5vw, 44px); font-weight: 800; color: #f1f5f9;
    letter-spacing: -.02em; line-height: 1.1;
  }
  .date-line2 {
    display: flex; align-items: baseline; gap: 8px; line-height: 1;
  }
  .date-num {
    font-family: var(--mono); font-size: clamp(38px, 5vw, 64px); font-weight: 900;
    color: #38bdf8; line-height: 1; letter-spacing: -2px;
    text-shadow: 0 0 20px rgba(56,189,248,0.5);
  }
  .date-month-txt {
    font-size: clamp(18px, 2.5vw, 30px); font-weight: 700;
    color: #e2e8f0; line-height: 1;
  }
  .date-year-txt {
    font-size: clamp(14px, 2vw, 24px); font-weight: 500; color: #64748b;
    font-family: var(--mono); line-height: 1;
  }
  .date-clock-big {
    font-family: var(--mono); font-size: clamp(18px, 2.5vw, 34px); font-weight: 800;
    color: var(--text); letter-spacing: .01em; line-height: 1; flex-shrink:0;
  }


  .export-bar { display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap; align-items:center; }
  .export-btn {
    display:flex; align-items:center; gap:5px;
    padding:6px 14px; border-radius:6px; cursor:pointer;
    font-size:12px; font-weight:500; font-family:var(--font);
    border:1px solid var(--border); background:var(--bg2); color:var(--text);
    transition:all .15s;
  }
  .export-btn:hover { border-color:var(--air); color:var(--air); }
  .export-btn svg { width:14px; height:14px; flex-shrink:0; }
  .export-btn.csv { border-color:#166534; color:#86efac; background:#052e16; }
  .export-btn.csv:hover { background:#074c23; }
  .export-btn.pdf { border-color:#991b1b; color:#fca5a5; background:#2d0a0a; }
  .export-btn.pdf:hover { background:#4a1010; }


  .date-picker-bar {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 0; margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .date-picker-bar label { font-size: 12px; color: var(--muted); }
  .date-picker-bar input[type=date] {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 6px; padding: 5px 10px;
    color: var(--text); font-family: var(--mono); font-size: 12px;
    cursor: pointer; outline: none;
  }
  .date-picker-bar input[type=date]:focus { border-color: var(--air); }
  .date-picker-bar button {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 6px; padding: 5px 12px;
    color: var(--muted); font-family: var(--font); font-size: 12px;
    cursor: pointer; transition: all .15s;
  }
  .date-picker-bar button:hover { color: var(--text); border-color: var(--air); }
  .date-picker-bar button.active { color: var(--air); border-color: var(--air); background: var(--bg2); }

  .wifi-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 0; margin-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .wifi-label { font-size: 11px; color: var(--muted); }
  .wifi-signal {
    display: flex; align-items: flex-end; gap: 2px; height: 16px;
  }
  .wifi-bar-item {
    width: 5px; border-radius: 2px;
    background: var(--border);
  }
  .wifi-bar-item.active { background: var(--success); }
  .wifi-bar-item.warn   { background: var(--prod); }
  .wifi-bar-item.weak   { background: var(--danger); }
  .wifi-text { font-size: 11px; font-weight: 600; }
  .wifi-text.good { color: var(--success); }
  .wifi-text.mid  { color: var(--prod); }
  .wifi-text.weak { color: var(--danger); }

  /* ── Toast Notification ─────────────────────── */
  #toast-container {
    position: fixed; bottom: 24px; right: 24px;
    display: flex; flex-direction: column; gap: 8px;
    z-index: 9999; pointer-events: none;
  }
  .toast {
    display: flex; align-items: center; gap: 10px;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 12px 16px;
    font-size: 13px; color: var(--text);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    pointer-events: all; min-width: 220px; max-width: 340px;
    animation: toastIn .25s ease;
    transition: opacity .3s, transform .3s;
  }
  .toast.hide { opacity:0; transform: translateX(20px); }
  .toast-icon { font-size: 16px; flex-shrink:0; }
  .toast-msg  { flex:1; line-height:1.4; }
  .toast.success { border-color: var(--success); }
  .toast.error   { border-color: var(--danger); }
  .toast.warn    { border-color: var(--prod); }
  .toast.info    { border-color: var(--air); }
  @keyframes toastIn {
    from { opacity:0; transform: translateX(20px); }
    to   { opacity:1; transform: translateX(0); }
  }


  /* ══════════════════════════════════════════
     v2.6.0 Responsive — 3 breakpoints
  ══════════════════════════════════════════ */

  /* ── Tablet 768–1023px ─────────────────── */
  @media (max-width: 1023px) {
    .container { max-width: 100%; padding: 0 14px; }
    .main-grid { grid-template-columns: 1fr; }
    .sidebar   { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .metric-grid { grid-template-columns: repeat(3, 1fr); }
    .status-row  { grid-template-columns: repeat(2, 1fr); }
    .hist-chart-wrap canvas { max-height: 240px; }
    .date-bar { gap: 4px; }
    .date-clock-big { font-size: clamp(18px, 3vw, 32px) !important; }
  }

  /* ── Phone 480–767px ───────────────────── */
  @media (max-width: 767px) {
    .container { padding: 0 10px; }
    .metric-grid { grid-template-columns: repeat(2, 1fr); }
    .status-row  { grid-template-columns: repeat(2, 1fr); }
    .chart-row   { grid-template-columns: 1fr !important; }
    .sidebar     { grid-template-columns: 1fr; }
    .tabs        { gap: 4px; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 4px; }
    .tab         { font-size: 11px; padding: 6px 10px; white-space: nowrap; flex-shrink: 0; }
    .hist-chart-wrap canvas { max-height: 200px; }
    .date-weekday-big { font-size: clamp(18px, 5vw, 32px) !important; }
    .date-num         { font-size: clamp(20px, 6vw, 36px) !important; }
