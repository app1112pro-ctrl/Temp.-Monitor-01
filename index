function updateUI(d) {
  // prev for delta
  if (state.air !== null) { state.prevAir=state.air; state.prevHumi=state.humi; state.prevProd=state.prod; }

  const _pf = (v, fallback) => { const n = parseFloat(v); return isNaN(n) ? fallback : n; };
  state._lastMqttMs = Date.now(); // v2.6.0: track last MQTT time
  state.air      = _pf(d.temp_air,     state.air);
  state.humi     = _pf(d.humidity,     state.humi);
  state.prod     = _pf(d.temp_product, state.prod);
  state.fan      = d.fan      || state.fan;
  state.prog     = d.program  || state.prog;
  state.sysState = d.sys_state|| state.sysState;
  state.fanMin   = d.fan_min_today !== undefined ? d.fan_min_today : state.fanMin;
  state.targetHumi = parseFloat(d.target_humi) || state.targetHumi;
  state.maxTemp    = parseFloat(d.max_temp)    || state.maxTemp;

  // Realtime page
  // v2.6.1 Fix: ใช้ !== null แทน truthy check (state.air=0 ก็ต้องแสดง)
  if (state.air  !== null) { $('v-air').textContent  = (+state.air).toFixed(1);  setDelta('d-air',  state.air,  state.prevAir,  'var(--air)'); }
  if (state.humi !== null) { $('v-humi').textContent = (+state.humi).toFixed(1); setDelta('d-humi', state.humi, state.prevHumi, 'var(--humi)'); }
  if (state.prod !== null) { $('v-prod').textContent = (+state.prod).toFixed(1); setDelta('d-prod', state.prod, state.prevProd, 'var(--prod)'); }

  // Fan status
  const fanEl = $('v-fan');
  fanEl.textContent = state.fan + ' (' + (d.fan_mode||'AUTO') + ')';
  fanEl.style.color = state.fan === 'ON' ? 'var(--success)' : 'var(--danger)';

  $('v-prog').textContent  = state.prog;
  $('v-fanmin').textContent = state.fanMin + ' นาที';
  // อัปเดต WiFi signal
  if (d.wifi !== undefined) {
    updateWifi(parseInt(d.wifi));
    const rssi = $('wifi-rssi');
    if (rssi) rssi.textContent = '(level ' + d.wifi + ')';
  }

  // Sys state
  const stateColors = { NORMAL:'var(--success)', NIGHT:'var(--night)', RAIN:'var(--rain)', OVERHEAT:'var(--over)' };
  const stateEl = $('v-state');
  stateEl.textContent = state.sysState;
  stateEl.style.color = stateColors[state.sysState] || 'var(--muted)';

  // Alert
  updateAlert(d);

  // Bars
  if (state.humi && state.targetHumi) {
    const hp = Math.min((state.humi / 100) * 100, 100).toFixed(0);
    $('bar-humi').style.width = hp + '%';
    $('bar-humi-now').textContent = state.humi.toFixed(0) + '%';
    $('bar-humi-target').textContent = state.targetHumi.toFixed(0) + '%';
    const overHumi = state.humi > state.targetHumi;
    $('bar-humi').style.background = overHumi ? 'var(--danger)' : 'var(--humi)';
    $('bar-humi-status').textContent = overHumi ? 'เกินเป้าหมาย' : 'ปกติ';
    $('bar-humi-status').style.color = overHumi ? 'var(--danger)' : 'var(--success)';
  }
  if (state.prod && state.maxTemp) {
    const pp = Math.min((state.prod / state.maxTemp) * 100, 100).toFixed(0);
    $('bar-prod').style.width = pp + '%';
    $('bar-prod-now').textContent = state.prod.toFixed(1) + '°C';
    $('bar-prod-max').textContent  = state.maxTemp.toFixed(0) + '°C';
    const overTemp = state.prod >= state.maxTemp * 0.9;
    $('bar-prod').style.background = overTemp ? 'var(--danger)' : 'var(--prod)';
    $('bar-prod-status').textContent = pp >= 90 ? 'ใกล้ขีดสูงสุด' : 'ปกติ';
    $('bar-prod-status').style.color = pp >= 90 ? 'var(--danger)' : 'var(--success)';
  }

  // Compare inside vs outside
  updateCompare();

  // Control page sidebar
  $('cs-prog').textContent  = state.prog;
  $('cs-fan').textContent   = state.fan + ' (' + (d.fan_mode||'') + ')';
  $('cs-fan').style.color   = state.fan === 'ON' ? 'var(--success)' : 'var(--danger)';
  $('cs-state').textContent = state.sysState;
  $('cs-state').style.color = stateColors[state.sysState] || 'var(--muted)';
  if (state.targetHumi) $('cs-humi').textContent = state.targetHumi.toFixed(0) + '%';
  if (state.maxTemp)    $('cs-temp').textContent = state.maxTemp.toFixed(0) + '°C';

  // Highlight active program button
  ['FRUIT','MEAT','HERB','CUSTOM'].forEach(p => {
    $('prog-'+p).classList.toggle('active', p === state.prog);
  });

  // Realtime chart
  pushRtChart(d);

  $('last-mqtt').textContent = new Date().toLocaleTimeString('th-TH');
}

function setDelta(id, now, prev, color) {
  if (prev === null) return;
  const diff = (now - prev).toFixed(1);
  const el = $(id);
  if (Math.abs(diff) < 0.15) { el.textContent = ''; return; }
  el.textContent = (diff > 0 ? '+' : '') + diff;
  el.style.color = diff > 0 ? 'var(--danger)' : 'var(--success)';
}

function updateAlert(d) {
  const ab = $('alert-box');
  let cls = 'alert-banner ';
  let msg = '';
  if (d.sys_state === 'OVERHEAT') {
    cls += 'alert-err'; msg = 'แจ้งเตือน: อุณหภูมิผลิตภัณฑ์เกินขีดสูงสุด — พัดลมเปิดบังคับ!';
  } else if (d.sys_state === 'RAIN' || d.rain_sensor === 'true') {
    cls += 'alert-rain'; msg = 'โหมดฝนตก: ตรวจพบฝน — พัดลมถูกปิดอัตโนมัติ';
  } else if (d.sys_state === 'NIGHT') {
    cls += 'alert-night'; msg = 'Night Guard: พักพัดลมในช่วงกลางคืน';
  } else if (d.fan_ineff === 'true') {
    cls += 'alert-err'; msg = 'แจ้งเตือน: พัดลมทำงานแต่ไม่มีประสิทธิภาพ — ตรวจสอบพัดลม';
  } else {
    cls += 'alert-ok'; msg = 'สถานะปกติ — ระบบทำงานอัตโนมัติ';
  }
  ab.className = cls;
  ab.textContent = msg;
}

