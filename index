//  ใช้สำหรับ histRange > 168 (30 วัน)
//  Daily columns: date, day_tair_avg, day_humi_avg, day_tprod_avg,
//                 night_tair_avg, night_humi_avg, night_tprod_avg, ...
// ─────────────────────────────────────────────────────────────
function parseAndRenderDaily(csv) {
  const lines = csv.trim().split('\n');
  if (lines.length < 2) { $('hist-status').textContent = 'ไม่มีข้อมูลใน Daily Sheet'; return; }

  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g,'').toLowerCase());
  const col = name => headers.indexOf(name);

  const iDate    = col('date');
  const iDAir    = col('day_tair_avg');
  const iDHumi   = col('day_humi_avg');
  const iDProd   = col('day_tprod_avg');
  const iNAir    = col('night_tair_avg');
  const iNHumi   = col('night_humi_avg');
  const iNProd   = col('night_tprod_avg');
  const iRain    = col('rain_count');
  const iProg    = col('program');
  const iDayOk   = col('day_ok');
  const iNightOk = col('night_ok');

  // แปลงแต่ละ row เป็น object ที่ renderHistCharts รับได้
  const rows = [];
  for (let i = 1; i < lines.length; i++) {
    if (!lines[i].trim()) continue;
    const c = lines[i].split(',').map(x => x.replace(/^"|"$/g,'').trim());
    const dateStr = iDate >= 0 ? c[iDate] : c[0];
    if (!dateStr || dateStr === '0000-00-00') continue;

    // แปลง "yyyy-MM-dd" → Date กลางวัน 12:00
    const ts = new Date(dateStr + 'T12:00:00');
    if (isNaN(ts.getTime())) continue;

    // ค่ากลางวัน + กลางคืน รวมเป็น avg รายวัน
    const dAir  = parseFloat(c[iDAir])  || null;
    const dHumi = parseFloat(c[iDHumi]) || null;
    const dProd = parseFloat(c[iDProd]) || null;
    const nAir  = parseFloat(c[iNAir])  || null;
    const nHumi = parseFloat(c[iNHumi]) || null;
    const nProd = parseFloat(c[iNProd]) || null;

    // ค่าเฉลี่ยวัน = (กลางวัน + กลางคืน) / 2 (ถ้ามีทั้งคู่)
    const avgPair = (a, b) => {
      if (a !== null && b !== null) return Math.round(((a + b) / 2) * 10) / 10;
      return a !== null ? a : b;
    };

    rows.push({
      ts,
      time:  dateStr,
      air:   avgPair(dAir,  nAir),
      humi:  avgPair(dHumi, nHumi),
      prod:  avgPair(dProd, nProd),
      fan:   '',
      prog:  iProg >= 0 ? (c[iProg] || '') : '',
      state: '',
      mode:  '',
      wifi:  0,
      rain:  iRain >= 0 ? (parseInt(c[iRain]) > 0 ? 1 : 0) : 0,
      // เก็บค่ากลางวัน/คืนแยกสำหรับ table
      dayAir: dAir, nightAir: nAir,
      dayHumi: dHumi, nightHumi: nHumi,
      dayProd: dProd, nightProd: nProd,
      dayOk:   iDayOk   >= 0 ? c[iDayOk]   : '',
      nightOk: iNightOk >= 0 ? c[iNightOk] : '',
    });
  }

  if (!rows.length) { $('hist-status').textContent = 'ไม่มีข้อมูลใน Daily Sheet'; return; }

  renderHistCharts(rows);
  renderHistTableDaily(rows.slice(-30).reverse());
  renderHistStats(rows);
}

