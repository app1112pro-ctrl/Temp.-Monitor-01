// โหลดข้อมูลวันนี้จาก Google Sheets เติม RT chart
function drawHistEndLabelDual(chart, data, color, axisId) {
  try {
    const lastIdx = data.length-1 - [...data].reverse().findIndex(v=>v!==null);
    if (lastIdx < 0 || lastIdx >= data.length) return;
    const val = data[lastIdx];
    if (val === null || isNaN(val)) return;
    const ctx    = chart.ctx;
    const ca     = chart.chartArea;
    const xScale = chart.scales && chart.scales.x;
    const yScale = chart.scales && chart.scales[axisId];
    if (!xScale || !yScale || !ca) return;
    const x = xScale.getPixelForValue(lastIdx);
    const y = yScale.getPixelForValue(val);
    ctx.save();
    ctx.beginPath();
    ctx.arc(x, y, 4, 0, Math.PI*2);
    ctx.fillStyle = color;
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.fillStyle = color;
    ctx.font = 'bold 11px IBM Plex Mono, monospace';
    ctx.textAlign = x > ca.right - 60 ? 'right' : 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(val.toFixed(1), x + (x > ca.right-60 ? -8 : 8), y - 8);
    ctx.restore();
  } catch(e) {}
}


// v2.5.0: parse timestamp รองรับ "2026-03-25 9:46" และ "2026-03-25 09:46"
function parseTimestamp(tsStr) {
  if (!tsStr) return null;
  // normalize: แทน space ด้วย T และ pad ชั่วโมงให้เป็น 2 หลัก
  // "2026-03-25 9:46" → "2026-03-25T09:46"
  // "2026-03-25 09:46" → "2026-03-25T09:46"
  const norm = tsStr.trim().replace(' ', 'T');
  // pad hour: "2026-03-25T9:46" → "2026-03-25T09:46"
  const padded = norm.replace(/T(\d):/, 'T0$1:');
  const dt = new Date(padded);
  return isNaN(dt) ? null : dt;
}


