function lastFilledIdx(arr) {
  for (let i = arr.length-1; i >= 0; i--) {
    if (arr[i] !== null) return i;
  }
  return -1;
}

function drawEndLabels(chart, datasets3) {
  try {
  const colors = ['#60a5fa','#34d399','#fb923c'];
  const keys   = ['air','humi','prod'];
  const ctx    = chart.ctx;
  const xScale = chart.scales && chart.scales.x;
  const yScale = chart.scales && (chart.scales.yT || chart.scales.y);
  if (!xScale || !yScale || typeof xScale.getPixelForValue !== 'function') return;
  ctx.save();
  keys.forEach((k, i) => {
    const idx = lastFilledIdx(datasets3[k]);
    if (idx < 0) return;
    const val = datasets3[k][idx];
    const x   = xScale.getPixelForValue(idx);
    const y   = yScale.getPixelForValue(val);
    ctx.fillStyle = colors[i];
    ctx.font = 'bold 11px IBM Plex Mono, monospace';
    ctx.textAlign = 'left';
    ctx.fillText(val.toFixed(1), x + 6, y - 4);
  });
  ctx.restore();
  } catch(e) {}
}

function pushRtChart(d) {
  if (!rtChart || pauseChartUpdates) return; // v0.3.0: skip เมื่อซ่อน
  const toNum = v => { const n = parseFloat(v); return isNaN(n) ? null : n; };
  const air  = toNum(d.temp_air);
  const humi = toNum(d.humidity);
  const prod = toNum(d.temp_product);
  if (air === null && humi === null && prod === null) return;
  const now = new Date();
  const slot = slotIndex(now);
  // อัปเดต slot ของเวลาปัจจุบัน
  if (air  !== null) rtAllData.air[slot]  = air;
  if (humi !== null) rtAllData.humi[slot] = humi;
  if (prod !== null) rtAllData.prod[slot] = prod;
  rtChart.data.datasets[0].data = rtAllData.air;
  rtChart.data.datasets[1].data = rtAllData.humi;
  rtChart.data.datasets[2].data = rtAllData.prod;

  // อัปเดต zones เฉพาะเมื่อต้องการ (ไม่ต้องทำทุก push)
  if (!rtChart._zonesSet) {
    rtChart.options.plugins.timeBg.zones = makeTimeZones(buildRtLabels(), 24);
    rtChart._zonesSet = true;
  }
  rtChart.update('none');
  drawEndLabels(rtChart, rtAllData);
}

