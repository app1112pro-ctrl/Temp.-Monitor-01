// ── Chart background plugin ─────────────────────────────
const timeBgPlugin = {
  id: 'timeBg',
  beforeDraw(chart, args, options) {
    try {
      if (!options || !options.zones || options.zones.length === 0) return;
      const ca = chart.chartArea;
      if (!ca) return;
      const xScale = chart.scales && chart.scales.x;
      if (!xScale || typeof xScale.getPixelForValue !== 'function') return;
      const {left, right, top, bottom} = ca;
      const ctx = chart.ctx;
      ctx.save();
      options.zones.forEach(z => {
        try {
          const x0 = xScale.getPixelForValue(z.from);
          const x1 = xScale.getPixelForValue(z.to + 1);
          const rx0 = Math.max(left, Math.min(x0, x1));
          const rx1 = Math.min(right, Math.max(x0, x1));
          if (rx1 <= rx0) return;
          ctx.fillStyle = z.color;
          ctx.fillRect(rx0, top, rx1 - rx0, bottom - top);
        } catch(ez) {}
      });
      ctx.restore();
    } catch(e) {}
    },
  afterDraw(chart, args, options) {
    try {
    if (!options || !options.seasons || options.seasons.length === 0) return;
    const ca = chart.chartArea;
    if (!ca) return;
    const xScale = chart.scales && chart.scales.x;
    if (!xScale || typeof xScale.getPixelForValue !== 'function') return;
    const ctx = chart.ctx;
    const isDark = !document.body.classList.contains('light');
    ctx.save();
    options.seasons.forEach(s => {
      const x0 = xScale.getPixelForValue(s.from);
      const x1 = xScale.getPixelForValue(s.to + 1);
      const cx  = Math.max(ca.left, Math.min(ca.right, (x0+x1)/2));
      const cy  = ca.top + 22;
      // วงกลมพื้นหลัง
      ctx.beginPath();
      ctx.arc(cx, cy, 14, 0, Math.PI*2);
      ctx.fillStyle = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
      ctx.fill();
      // สัญลักษณ์
      ctx.font = '15px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(s.sym, cx, cy);
      // ชื่อย่อ
      if (x1 - x0 > 60) {
        ctx.font = isDark
          ? '500 9px IBM Plex Sans Thai, sans-serif'
          : '500 9px IBM Plex Sans Thai, sans-serif';
        ctx.fillStyle = isDark ? 'rgba(200,220,255,0.7)' : 'rgba(60,60,100,0.7)';
        ctx.fillText(s.label, cx, cy + 18);
      }
    });
    ctx.restore();
    } catch(e) {}
  }
};
Chart.register(timeBgPlugin);

// Plugin วาด end-labels บน RT chart — ถาวร ไม่หายหลัง hover
const rtEndLabelsPlugin = {
  id: 'endLabels',
  afterDraw(chart) {
    try {
      // อ่านจาก chart.data.datasets โดยตรง (ไม่ขึ้นกับ rtAllData global)
      // v2.6.0: ใช้ borderColor จาก dataset โดยตรง — ไม่ hardcode
      const datasets = chart.data.datasets.map((ds) => ({
        data:  ds.data,
        color: ds.borderColor || '#ffffff',
        axis:  ds.yAxisID    || 'yT',
      }));
      const ctx = chart.ctx;
      const ca  = chart.chartArea;
      if (!ca) return;
      // v2.6.1 Fix: เพิ่ม MIN_GAP และ track ทั้ง x,y เพื่อป้องกัน overlap
      const MIN_GAP_Y = 22;  // เพียงพอสำหรับ font 11px
      const placed = []; // [{x, y, adj}]
      ctx.save();
      datasets.forEach((ds, dsIdx) => {
        const lastIdx = lastFilledIdx(ds.data);
        if (lastIdx < 0) return;
        const val = ds.data[lastIdx];
        if (val === null || isNaN(val)) return;
        const xScale = chart.scales && chart.scales.x;
        const yScale = chart.scales && chart.scales[ds.axis];
        if (!xScale || !yScale || typeof xScale.getPixelForValue !== 'function') return;
        const x = xScale.getPixelForValue(lastIdx);
        const y = yScale.getPixelForValue(val);
        // v2.6.1 Fix: anti-overlap Y — ดัน label ออกจาก placed เดิม
        let adj = y;
        placed.forEach(p => {
          if (Math.abs(adj - p.adj) < MIN_GAP_Y) {
            adj = p.adj + (adj >= p.adj ? MIN_GAP_Y : -MIN_GAP_Y);
          }
        });
        placed.push({ x, y, adj });
        // วงกลมที่จุดข้อมูลจริง
        ctx.beginPath();
        ctx.arc(x, y, 5, 0, Math.PI * 2);
        ctx.fillStyle = ds.color;
        ctx.fill();
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 1.5;
        ctx.stroke();
        // เส้นเชื่อมถ้า label ถูกเลื่อน
        if (Math.abs(adj - y) > 3) {
          ctx.beginPath();
          ctx.strokeStyle = ds.color + '70';
          ctx.lineWidth = 0.8;
          ctx.setLineDash([2, 3]);
          ctx.moveTo(x, y);
          ctx.lineTo(x, adj);
          ctx.stroke();
          ctx.setLineDash([]);
        }
        // ตัวเลข: สลับซ้าย-ขวาตาม dsIdx เพื่อลด horizontal overlap
        // yT มี 2 เส้น (air, prod) → สลับ offset
        const isRight = x > ca.right - 80;
        // v2.6.1 Fix: offset X แตกต่างกันตาม axis + index
        let offsetX;
        if (ds.axis === 'yH') {
          // ความชื้น อยู่แกนขวา — วาดชิดขวา
          offsetX = isRight ? -10 : 8;
        } else {
          // อุณหภูมิ อยู่แกนซ้าย — สลับ offset ตาม dsIdx
          offsetX = isRight ? -(10 + dsIdx * 0) : (8 + dsIdx * 36);
        }
        ctx.fillStyle = ds.color;
        ctx.font = 'bold 11px IBM Plex Mono, monospace';
        ctx.textAlign = isRight ? 'right' : 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText(val.toFixed(1), x + (isRight ? -10 : offsetX), adj);
      });
      ctx.restore();
    } catch(e) {}
  }
};
Chart.register(rtEndLabelsPlugin);



// สร้าง zones สำหรับ time-based charts
function makeTimeZones(labels, rangeH) {
  const zones = [];
  if (rangeH > 168) return zones;
  const isDark = !document.body.classList.contains('light');
  const NIGHT = isDark ? 'rgba(8,15,50,0.55)'  : 'rgba(180,200,255,0.22)';
  const DAWN  = isDark ? 'rgba(100,55,0,0.45)' : 'rgba(255,150,20,0.20)';
  labels.forEach((lbl, idx) => {
    const match = lbl.match(/(\d{1,2}):(\d{2})/);
    if (!match) return;
    const totalMin = parseInt(match[1])*60 + parseInt(match[2]);
    let color = null;
    if (totalMin >= 19*60 || totalMin < 6*60)       color = NIGHT;
    else if (totalMin < 8*60 || totalMin >= 17*60)  color = DAWN;
    if (color) {
      const last = zones[zones.length-1];
      if (last && last.color === color && last.to === idx-1) { last.to = idx; }
      else zones.push({ from: idx, to: idx, color });
    }
  });
  return zones;
}


function makeSeasonZones(labels) {
  const zones = [];
  const isDark = !document.body.classList.contains('light');
  const HOT   = isDark ? 'rgba(100,35,0,0.40)'  : 'rgba(255,140,40,0.20)';  // ร้อน: ส้มทอง
  const RAIN  = isDark ? 'rgba(0,40,90,0.40)'   : 'rgba(40,120,240,0.20)';  // ฝน: ฟ้าเข้ม
  const COLD  = isDark ? 'rgba(30,10,70,0.40)'  : 'rgba(120,80,210,0.20)';  // หนาว: ม่วง

  labels.forEach((lbl, idx) => {
    // parse เดือนจาก label เช่น "มี.ค. 68" หรือ "สัปดาห์ 22/3"
    let month = null, slabel = '';
    // ลอง match ชื่อเดือนภาษาไทยย่อ
    const thMonths = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.',
                      'ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
    thMonths.forEach((m,i) => { if (lbl.includes(m)) month = i+1; });
    // ลอง match ตัวเลขเดือน เช่น "22/3"
    if (!month) {
      const m2 = lbl.match(/\/(\d{1,2})/);
      if (m2) month = parseInt(m2[1]);
    }
    if (!month) return;
    let color = null;
    let sym = null;
    if (month >= 3 && month <= 6)       { color = HOT;  sym = '☀'; slabel = 'ร้อน'; }
    else if (month >= 7 && month <= 10) { color = RAIN; sym = '⛈'; slabel = 'ฝน';   }
    else                                { color = COLD; sym = '❄'; slabel = 'หนาว';}
    const last = zones[zones.length-1];
    if (last && last.color === color && last.to === idx-1) {
      last.to = idx;
    } else {
      zones.push({ from: idx, to: idx, color, sym, label: slabel });
    }
  });
  // สร้าง seasons array (zone ที่มีสัญลักษณ์) สำหรับ afterDraw
  const seasons = zones.map(z => ({ ...z }));
  return { zones, seasons };
}

