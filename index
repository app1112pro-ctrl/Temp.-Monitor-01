}

async function fetchViaAppsScript(lat, lon) {
  if (!CFG.gasWeatherUrl || CFG.gasWeatherUrl === 'YOUR_GAS_WEATHER_URL') return null;
  const res  = await fetch(CFG.gasWeatherUrl + '?lat=' + lat + '&lon=' + lon);
  const json = await res.json();
  if (json.error) throw new Error(json.error);
  return {
    temp:      json.temp.toFixed(1),
    humi:      Math.round(json.humi),
    feelsLike: (json.feelsLike||json.temp).toFixed(1),
    wind:      (json.wind||0).toFixed(1),
    windDir:   windDirLabel(json.windDir||0),
    rain:      (json.rain||0).toFixed(1),
    cloud:     json.cloud||0,
    desc:      getWeatherDesc(json.code||0),
    time:      json.time || new Date().toLocaleString('th-TH'),
  };
}

async function fetchOpenMeteo(lat, lon) {
  const url = "https://api.open-meteo.com/v1/forecast"
    + "?latitude=" + lat + "&longitude=" + lon
    + "&current=temperature_2m,relative_humidity_2m,apparent_temperature,wind_speed_10m,wind_direction_10m,precipitation,cloud_cover,weather_code"
    + "&forecast_days=1&timezone=Asia%2FBangkok";
  const res  = await fetch(url);
  if (!res.ok) throw new Error('HTTP ' + res.status);
  const json = await res.json();
  const cur  = json.current;
  return {
    temp:      cur.temperature_2m.toFixed(1),
    humi:      Math.round(cur.relative_humidity_2m),
    feelsLike: cur.apparent_temperature.toFixed(1),
    wind:      cur.wind_speed_10m.toFixed(1),
    windDir:   windDirLabel(cur.wind_direction_10m),
    rain:      cur.precipitation.toFixed(1),
    cloud:     cur.cloud_cover,
    desc:      getWeatherDesc(cur.weather_code),
    time:      cur.time.replace("T"," ").slice(0,16),
  };
}

function windDirLabel(deg) {
  const dirs = ["เหนือ","ตต.เหนือ","ตะวันออกเฉียงเหนือ","ตอ.เหนือ","ตะวันออก","ตอ.ใต้","ตะวันออกเฉียงใต้","ตต.ใต้","ใต้","ตต.ใต้","ตะวันตกเฉียงใต้","ตต.ใต้","ตะวันตก","ตต.เหนือ","ตะวันตกเฉียงเหนือ","ตต.เหนือ"];
  return dirs[Math.round(deg/22.5) % 16];
}

function getWeatherDesc(code) {
  if (code === 0) return "ท้องฟ้าแจ่มใส";
  if (code <= 2)  return "มีเมฆบางส่วน";
  if (code === 3) return "มีเมฆมาก";
  if (code <= 49) return "หมอก";
  if (code <= 59) return "ฝนปรอย";
  if (code <= 69) return "ฝนตก";
  if (code <= 79) return "หิมะ";
  if (code <= 84) return "ฝนห่าใหญ่";
  if (code <= 99) return "พายุฝนฟ้าคะนอง";
  return "ไม่ทราบ";
}

async function fetchWeather() {
  if (true) { // ดึงจาก Open-Meteo โดยตรงเสมอ — แม่นยำและไม่มี CORS
    await fetchWeatherDirect();
    return;
  }
  try {
    const res  = await fetch(CFG.weatherUrl);
    const text = await res.text();
    const lines = text.trim().split('\n');
    // อ่าน header เพื่อ map column (WeatherData: Timestamp, OutsideTemp, OutsideHumidity)
    const hdrs = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g,'').toLowerCase());
    const iTs   = hdrs.findIndex(h => h.includes('timestamp') || h.includes('time'));
    const iTemp = hdrs.findIndex(h => h.includes('temp'));
    const iHumi = hdrs.findIndex(h => h.includes('humid'));
    const last  = lines[lines.length-1].split(',').map(c => c.replace(/^"|"$/g,'').trim());
    const tsVal = new Date(last[iTs >= 0 ? iTs : 0]);
    weatherState = {
      temp: parseFloat(last[iTemp >= 0 ? iTemp : 1]).toFixed(1),
      humi: Math.round(parseFloat(last[iHumi >= 0 ? iHumi : 2])),
      time: isNaN(tsVal) ? new Date().toLocaleTimeString('th-TH') : tsVal.toLocaleTimeString('th-TH'),
    };
    updateWeatherUI();
        updateCompare(); // v2.5.1
  } catch(e) {
    console.warn('Weather fetch failed:', e);
  }
}

