//  v2.6.2: อัปเดต metric cards จากแถวล่าสุดใน Sheets
//  เรียกหลัง loadTodayIntoRtChart — แสดงค่าล่าสุดทันทีโดยไม่รอ MQTT
// ════════════════════════════════════════
async function updateLatestStateFromSheets() {
  if (!CFG.sheetsUrl || CFG.sheetsUrl.includes('YOUR_')) return;
  try {
    const res  = await fetch(CFG.sheetsUrl + '&t=' + Date.now());
    const text = await res.text();
    const lines = text.trim().split('\n');
    if (lines.length < 2) return;

    const headers = lines[0].split(',').map(h => h.replace(/^"|"$/g,'').trim().toLowerCase());
    const col = name => headers.indexOf(name);
    const iTime  = col('time');
    const iAir   = col('temp_air');
    const iHumi  = col('humidity');
    const iProd  = col('temp_product');
    const iFan   = col('fan');
    const iMode  = col('fan_mode');
    const iProg  = col('program');
    const iState = col('sys_state');
    const iWifi  = col('wifi');
    const iRain  = col('rain_sensor');
    const iIneff = col('fan_ineff');
    const iFanMin= col('fan_min_today');
    const iTHumi = col('target_humi');
    const iMaxT  = col('max_temp');

    // ค้นหาแถวล่าสุดที่มีข้อมูลวันนี้
    const now      = new Date();
    const todayStr = now.getFullYear() + '-'
      + String(now.getMonth()+1).padStart(2,'0') + '-'
      + String(now.getDate()).padStart(2,'0');

    let lastRow = null;
    for (let i = lines.length - 1; i >= 1; i--) {
      const line = lines[i].trim();
      if (!line) continue;
      const cols = line.split(',').map(c => c.replace(/^"|"$/g,'').trim());
      const ts   = cols[iTime] || '';
      if (ts.slice(0,10) === todayStr) { lastRow = cols; break; }
    }

    // ถ้าไม่มีวันนี้ ให้ใช้แถวสุดท้ายที่มีอยู่ (ข้อมูลล่าสุดในฐานข้อมูล)
    if (!lastRow) {
      for (let i = lines.length - 1; i >= 1; i--) {
        const line = lines[i].trim();
        if (!line) continue;
        lastRow = line.split(',').map(c => c.replace(/^"|"$/g,'').trim());
        break;
      }
    }
    if (!lastRow) return;

    // สร้าง data object แบบเดียวกับที่ MQTT ส่งมา
    const d = {};
    const _s = (idx) => idx >= 0 ? (lastRow[idx] || '') : '';
    const _f = (idx) => idx >= 0 ? parseFloat(lastRow[idx]) : NaN;

    d.temp_air     = _s(iAir);
    d.humidity     = _s(iHumi);
    d.temp_product = _s(iProd);
    d.fan          = _s(iFan);
    d.fan_mode     = _s(iMode);
    d.program      = _s(iProg);
    d.sys_state    = _s(iState);
    d.wifi         = _s(iWifi);
    d.rain_sensor  = _s(iRain);
    d.fan_ineff    = _s(iIneff);
    d.fan_min_today= !isNaN(_f(iFanMin)) ? _f(iFanMin) : undefined;
    d.target_humi  = _s(iTHumi);
    d.max_temp     = _s(iMaxT);

    // ตรวจว่ามีค่าจริง (ไม่ใช่ ERR หรือ ว่าง)
    const airOK  = d.temp_air  && d.temp_air  !== 'ERR' && !isNaN(parseFloat(d.temp_air));
    const humiOK = d.humidity  && d.humidity  !== 'ERR' && !isNaN(parseFloat(d.humidity));
    const prodOK = d.temp_product && d.temp_product !== 'ERR' && !isNaN(parseFloat(d.temp_product));

    if (!airOK && !humiOK && !prodOK) {
      logMqtt('[Sheets] ไม่พบข้อมูลเซนเซอร์ใน Sheets', '#fbbf24');
      return;
    }

    // อัปเดต state และ UI เหมือน MQTT มาถึง
    updateUI(d);
    logMqtt('[Sheets] อัปเดต metrics จากข้อมูลล่าสุด (' + (_s(iTime) || 'ไม่ทราบเวลา') + ')', '#60a5fa');

  } catch(e) {
    logMqtt('[Sheets] updateLatest error: ' + e.message, '#f87171');
  }
}


async function fetchWeatherDirect() {
  const LAT = 12.623387687025879;
  const LON = 101.4307925089054;

  // ลำดับ fallback: 1) Apps Script proxy  2) Open-Meteo โดยตรง  3) wttr.in (no-cors)
  const sources = [
    // 1. Apps Script proxy — ต้องตั้งค่า GAS_WEATHER_URL ใน CFG
    () => fetchViaAppsScript(LAT, LON),
    // 2. Open-Meteo โดยตรง (อาจถูกบล็อกบน GitHub Pages)
    () => fetchOpenMeteo(LAT, LON),
  ];

  for (const src of sources) {
    try {
      const data = await src();
      if (data) {
        weatherState = { ...data, lat: LAT, lon: LON };
        updateWeatherUI();
        updateCompare(); // v2.5.1: trigger หลัง weather update
        logMqtt("[Weather] OK: " + weatherState.temp + "°C " + weatherState.humi + "% " + (weatherState.desc||''), "#22d3ee");
        return;
      }
    } catch(e) {
      logMqtt("[Weather] source failed: " + e.message, "#fbbf24");
