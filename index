function connectMQTT() {
  // ── v0.3.0: cleanup ก่อน reconnect ป้องกัน listener leak ──────────────
  if (mqttClient) {
    try {
      mqttClient.removeAllListeners();
      mqttClient.end(true);
    } catch(e) {}
    mqttClient = null;
  }

  const url = `wss://${CFG.mqttHost}:${CFG.mqttPort}/mqtt`;
  mqttClient = mqtt.connect(url, {
    username:        CFG.mqttUser,
    password:        CFG.mqttPass,
    clientId:        CFG.mqttClient,
    reconnectPeriod: 0,        // v0.3.0: ปิด auto-reconnect ของ library
    connectTimeout:  10000,    // ใช้ reconnect logic ของเราแทน
    clean:           true,
  });

  mqttClient.on('connect', () => {
    mqttReconnectDelay = 5000; // reset delay
    $('conn-dot').className = 'conn-dot on';
    $('conn-label').textContent = 'เชื่อมต่อแล้ว';
    logMqtt('Connected to HiveMQ Cloud', '#34d399');
    mqttClient.subscribe('squid_dry/data');
    mqttClient.subscribe('squid_dry/status');
    mqttClient.subscribe('squid_dry/alert');
    logMqtt('Subscribed: squid_dry/data, squid_dry/status, squid_dry/alert', '#5a7090');
  });

  mqttClient.on('message', (topic, payload) => {
    try {
      const d = JSON.parse(payload.toString());
      if (topic === 'squid_dry/data')   scheduleUIUpdate(d);
      if (topic === 'squid_dry/status') scheduleUIUpdate(d); // status มี field เดียวกัน
      if (topic === 'squid_dry/alert')  handleAlert(d);
    } catch(e) { logMqtt('Parse error: ' + e.message, '#f87171'); }
  });

  mqttClient.on('error', (err) => {
    logMqtt('MQTT error: ' + err.message, '#f87171');
    $('conn-dot').className = 'conn-dot';
    $('conn-label').textContent = 'เชื่อมต่อไม่ได้';
  });

  mqttClient.on('close', () => {
    $('conn-dot').className = 'conn-dot';
    $('conn-label').textContent = 'กำลังเชื่อมต่อ...';
    // v0.3.0: exponential backoff reconnect
    logMqtt('Reconnecting in ' + (mqttReconnectDelay/1000) + 's...', '#5a7090');
    setTimeout(() => {
      if (!document.hidden) connectMQTT(); // ไม่ reconnect ตอนหน้าซ่อน
    }, mqttReconnectDelay);
    mqttReconnectDelay = Math.min(mqttReconnectDelay * 1.5, 60000); // max 60s
  });

  mqttClient.on('offline', () => {
    $('conn-dot').className = 'conn-dot';
    $('conn-label').textContent = 'ออฟไลน์';
  });
}


function handleAlert(d) {
  const msgs = {
    overheat:        'ร้อนเกิน: temp_product = ' + d.temp_product + '°C',
    overheat_cleared:'อุณหภูมิกลับสู่ปกติ',
    rain_detected:   'ตรวจพบฝน (sensor:' + d.sensor + ', algo:' + d.algo + ')',
    rain_cleared:    'ฝนหยุดแล้ว — ระบบกลับสู่ปกติ',
    rain_cleared_manual: 'ยกเลิก Rain Mode โดยผู้ใช้',
    fan_ineffective: 'พัดลมไม่มีประสิทธิภาพ (drop:' + d.temp_drop + '°C, ' + d.fan_on_min + ' นาที)',
    humidity_high:   'ความชื้นสูงนาน: ' + d.humidity + '% (target:' + d.target + '%)',
  };
  const msg = msgs[d.event] || JSON.stringify(d);
  logMqtt('[ALERT] ' + msg, '#f87171');
  logCmd('[ALERT] ' + msg);
}

function publish(payload) {
  if (!mqttClient || !mqttClient.connected) {
    logCmd('ไม่ได้เชื่อมต่อ MQTT', '#f87171');
    return false;
  }
  mqttClient.publish('squid_dry/command', JSON.stringify(payload));
  logCmd('Sent: ' + JSON.stringify(payload));
  return true;
}

