function parseAndRenderHistory(csv) {
  const lines = csv.trim().split('\n');
  if (lines.length < 2) { $('hist-status').textContent = 'ไม่มีข้อมูลใน Sheet'; return; }

  // parse header อย่างถูกต้อง
  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g,'').toLowerCase());
  const col = name => headers.indexOf(name);

  const iTime  = col('time');
  const iAir   = col('temp_air');
  const iHumi  = col('humidity');
  const iProd  = col('temp_product');
  const iFan   = col('fan');
  const iProg  = col('program');
  const iState = col('sys_state');
  const iMode  = col('fan_mode');
  const iWifi  = col('wifi');
  const iRain  = col('rain_sensor');

  // v2.6.0: คำนวณ cutoff จาก date picker ถ้ามี ไม่งั้นใช้ histRange
  const TZ_OFFSET_MS = 7 * 3600000;
  const fromEl = document.getElementById('hist-date-from');
  const toEl   = document.getElementById('hist-date-to');
  let cutoffMs, cutoffEndMs;
  if (fromEl && fromEl.value) {
    // ใช้ date picker — parse เป็น local time
    cutoffMs    = new Date(fromEl.value + 'T00:00:00').getTime();
    cutoffEndMs = toEl && toEl.value
      ? new Date(toEl.value + 'T23:59:59').getTime()
      : cutoffMs + 86400000;
  } else {
    cutoffMs    = Date.now() - histRange * 3600000;
    cutoffEndMs = Date.now() + 86400000;
  }
  const rows = [];

  // v0.3.0: จำกัด MAX_HIST_ROWS ป้องกัน parse CSV ทั้งหมด
  const MAX_HIST_ROWS = 5000;
  const startLine = Math.max(1, lines.length - MAX_HIST_ROWS);

  for (let i = startLine; i < lines.length; i++) {
    if (!lines[i].trim()) continue;
    const cols = lines[i].split(',').map(c => c.replace(/^"|"$/g,'').trim());
    const tsStr = iTime >= 0 ? cols[iTime] : cols[0];
    if (!tsStr) continue;
    const ts = parseTimestamp(tsStr);
    if (!ts) continue;
    if (ts.getTime() < cutoffMs - TZ_OFFSET_MS) continue;
    rows.push({
      ts,
      time: ts.toLocaleString('th-TH'),
      air:   iAir  >= 0 ? (parseFloat(cols[iAir])  || null) : null,
      humi:  iHumi >= 0 ? (parseFloat(cols[iHumi]) || null) : null,
      prod:  iProd >= 0 ? (parseFloat(cols[iProd]) || null) : null,
      fan:   iFan  >= 0 ? (cols[iFan]  || '').toUpperCase() : '',
      prog:  iProg >= 0 ? (cols[iProg] || '') : '',
      state: iState>= 0 ? (cols[iState]|| '') : '',
      mode:  iMode >= 0 ? (cols[iMode] || '') : '',
      wifi:  iWifi >= 0 ? (parseInt(cols[iWifi]) || 0) : 0,
      rain:  iRain >= 0 ? ((cols[iRain]||'').toLowerCase()==='true' ? 1 : 0) : 0,
    });
  }

  if (!rows.length) { $('hist-status').textContent = 'ไม่มีข้อมูลในช่วงเวลาที่เลือก'; return; }

  // force update X ticks เมื่อ histRange เปลี่ยน
  [histTempChart, histHumiChart].forEach(ch => {
    if (ch) { ch.options.scales.x.ticks.autoSkip = false; ch.update('none'); }
  });

  renderHistCharts(rows);
  renderHistTable(rows.slice(-30).reverse());
  renderHistStats(rows);
  $('hist-status').textContent = 'โหลดสำเร็จ · ' + new Date().toLocaleTimeString('th-TH');
}


function renderHistCharts(rows) {
  // เลือก format label ตามช่วงเวลา
  const rangeH = histRange;
  const fmtLabel = (ts) => {
    if (rangeH <= 24) {
      // 24 ชม. → แสดงเฉพาะ HH:MM เริ่มจาก 00:00
      return ts.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'});
    } else {
      // 3วัน+ → แสดง ว/ด HH:MM
      return ts.toLocaleDateString('th-TH',{day:'numeric',month:'numeric'})
             + ' ' + ts.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'});
    }
  };
  // 24 ชม. — group เป็นรายชั่วโมง เอา avg ของแต่ละชั่วโมง
  let labels, airData, humiData;
  const avg = arr => arr.length ? +(arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(1) : null;
  let prodData = [];

  if (rangeH <= 24) {
    // 24 ชม. — bucket รายชั่วโมง 00:00-23:00
    const buckets = {};
    for (let h=0; h<24; h++) buckets[String(h).padStart(2,'0')+':00'] = {air:[],humi:[]};
    rows.forEach(r => {
      const hkey = String(r.ts.getHours()).padStart(2,'0')+':00';
      if (buckets[hkey]) {
        if (r.air  !== null && !isNaN(r.air))  buckets[hkey].air.push(r.air);
        if (r.humi !== null && !isNaN(r.humi)) buckets[hkey].humi.push(r.humi);
        if (!buckets[hkey].prod) buckets[hkey].prod=[];
        if (r.prod !== null && !isNaN(r.prod)) buckets[hkey].prod.push(r.prod);
        if (!buckets[hkey].wifi) buckets[hkey].wifi=[];
        if (r.wifi !== undefined) buckets[hkey].wifi.push(r.wifi);
        if (!buckets[hkey].rain) buckets[hkey].rain=[];
        buckets[hkey].rain.push(r.rain||0);
      }
    });
    labels   = Object.keys(buckets);
    airData  = labels.map(k => avg(buckets[k].air));
    humiData = labels.map(k => avg(buckets[k].humi));
    prodData = labels.map(k => avg(buckets[k].prod||[]));
    // wifiData/rainData สำหรับ WiFi+Rain charts (pass ผ่าน rows)
    // ใช้ rows โดยตรงใน updateWifiRainCharts

  } else if (rangeH <= 72) {
    // 3 วัน — bucket ราย 3 ชั่วโมง เช่น 00:00, 03:00, 06:00...
    const step = 3;
    const buckets = {};
    for (let d=0; d<3; d++) {
      for (let h=0; h<24; h+=step) {
        const dt = new Date(Date.now() - (2-d)*86400000);
        const key = dt.toLocaleDateString('th-TH',{day:'numeric',month:'numeric'})
                  + ' ' + String(h).padStart(2,'0')+':00';
        buckets[key] = {air:[],humi:[]};
      }
    }
    rows.forEach(r => {
      const slotH = Math.floor(r.ts.getHours()/step)*step;
      const key = r.ts.toLocaleDateString('th-TH',{day:'numeric',month:'numeric'})
                + ' ' + String(slotH).padStart(2,'0')+':00';
      if (buckets[key]) {
        if (r.air  !== null && !isNaN(r.air))  buckets[key].air.push(r.air);
        if (r.humi !== null && !isNaN(r.humi)) buckets[key].humi.push(r.humi);
      }
    });
    labels   = Object.keys(buckets);
    airData  = labels.map(k => avg(buckets[k].air));
    humiData = labels.map(k => avg(buckets[k].humi));

  } else if (rangeH <= 168) {
    // 7 วัน — 28 slots (7วัน x 4 slot/วัน) วันปัจจุบันอยู่วันที่ 6
    const STEP_H = 6, TOTAL_D7 = 7, CUR_D7 = 6;
    const today7 = new Date().setHours(0,0,0,0);
    const start7 = today7 - (CUR_D7-1)*86400000;
    const bk7 = {}, ord7 = [];
    for (let d=0; d<TOTAL_D7; d++) {
      for (let h=0; h<24; h+=STEP_H) {
        const ms = start7 + d*86400000 + h*3600000;
        const dt = new Date(ms);
        const key = dt.toLocaleDateString('th-TH',{day:'numeric',month:'numeric'})
                  + ' ' + String(h).padStart(2,'0')+':00';
        bk7[ms] = {air:[], humi:[], key}; ord7.push(ms);
      }
    }
    rows.forEach(r => {
      const rH = Math.floor(r.ts.getHours()/STEP_H)*STEP_H;
      const ms = new Date(r.ts.getFullYear(),r.ts.getMonth(),r.ts.getDate(),rH).getTime();
      if (bk7[ms]) {
        if (r.air  !== null && !isNaN(r.air))  bk7[ms].air.push(r.air);
        if (r.humi !== null && !isNaN(r.humi)) bk7[ms].humi.push(r.humi);
      }
    });
    labels   = ord7.map(k => bk7[k].key);
    airData  = ord7.map(k => avg(bk7[k].air));
    humiData = ord7.map(k => avg(bk7[k].humi));
    prodData = labels.map(() => null); // ไม่มี prod ใน bucket นี้

  } else if (rangeH <= 720) {
    // 30 วัน — 30 วัน วันปัจจุบันอยู่ตำแหน่งที่ 25 เฉลี่ยรายวัน
    const TOTAL_D = 30;
    const CUR_D   = 25;
    const todayMs = new Date().setHours(0,0,0,0);
    const startMs = todayMs - (CUR_D - 1) * 86400000;
    const dayBuckets = {};
    const dayOrder   = [];
    for (let i = 0; i < TOTAL_D; i++) {
      const ms  = startMs + i * 86400000;
      const dt  = new Date(ms);
      const key = dt.toLocaleDateString('th-TH',{day:'numeric',month:'short'});
      const dk  = dt.toISOString().slice(0,10);
      dayBuckets[dk] = {air:[], humi:[], key};
      dayOrder.push(dk);
    }
    rows.forEach(r => {
      const dk = r.ts.toISOString().slice(0,10);
      if (dayBuckets[dk]) {
        if (r.air  !== null && !isNaN(r.air))  dayBuckets[dk].air.push(r.air);
        if (r.humi !== null && !isNaN(r.humi)) dayBuckets[dk].humi.push(r.humi);
      }
    });
    labels   = dayOrder.map(k => dayBuckets[k].key);
    airData  = dayOrder.map(k => avg(dayBuckets[k].air));
    humiData = dayOrder.map(k => avg(dayBuckets[k].humi));
    prodData = labels.map(() => null); // ไม่มี prod ใน bucket นี้

  } else if (rangeH <= 4380) {
    // 6 เดือน — 6 เดือน เฉลี่ยรายเดือน label เป็น "มี.ค." เดือนปัจจุบันอยู่ที่ 5
    const TOTAL_6M = 6;
    const CUR_6M   = 5;
    const now6     = new Date();
    const curMo6   = now6.getFullYear()*12 + now6.getMonth();
    const start6   = curMo6 - (CUR_6M - 1);
    const mo6Buckets = {};
    const mo6Order   = [];
    for (let i = 0; i < TOTAL_6M; i++) {
      const moIdx = start6 + i;
      const yr    = Math.floor(moIdx / 12);
      const mo    = moIdx % 12;
      const dt    = new Date(yr, mo, 1);
      const key   = dt.toLocaleDateString('th-TH',{month:'short'});
      const mkey  = yr*100 + mo;
      mo6Buckets[mkey] = {air:[], humi:[], key};
      mo6Order.push(mkey);
    }
    rows.forEach(r => {
      const mkey = r.ts.getFullYear()*100 + r.ts.getMonth();
      if (mo6Buckets[mkey]) {
        if (r.air  !== null && !isNaN(r.air))  mo6Buckets[mkey].air.push(r.air);
        if (r.humi !== null && !isNaN(r.humi)) mo6Buckets[mkey].humi.push(r.humi);
      }
    });
    labels   = mo6Order.map(k => mo6Buckets[k].key);
    airData  = mo6Order.map(k => avg(mo6Buckets[k].air));
    humiData = mo6Order.map(k => avg(mo6Buckets[k].humi));
    prodData = labels.map(() => null); // ไม่มี prod ใน bucket นี้

  } else {
    // 12 เดือน — 12 เดือน เฉลี่ยรายเดือน label เป็น "มี.ค." เดือนปัจจุบันอยู่ที่ 10
    const TOTAL_MO = 12;
    const CUR_MO   = 10;
    const now      = new Date();
    const curMoIdx = now.getFullYear()*12 + now.getMonth();
    const startMo  = curMoIdx - (CUR_MO - 1);
    const moBuckets = {};
    const moOrder   = [];
    for (let i = 0; i < TOTAL_MO; i++) {
      const moIdx = startMo + i;
      const yr    = Math.floor(moIdx / 12);
      const mo    = moIdx % 12;
      const dt    = new Date(yr, mo, 1);
      const key   = dt.toLocaleDateString('th-TH',{month:'short'});
      const mkey  = yr*100 + mo;
      moBuckets[mkey] = {air:[], humi:[], key};
      moOrder.push(mkey);
    }
    rows.forEach(r => {
      const mkey = r.ts.getFullYear()*100 + r.ts.getMonth();
      if (moBuckets[mkey]) {
        if (r.air  !== null && !isNaN(r.air))  moBuckets[mkey].air.push(r.air);
        if (r.humi !== null && !isNaN(r.humi)) moBuckets[mkey].humi.push(r.humi);
      }
    });
    labels   = moOrder.map(k => moBuckets[k].key);
    airData  = moOrder.map(k => avg(moBuckets[k].air));
    humiData = moOrder.map(k => avg(moBuckets[k].humi));
    prodData = labels.map(() => null); // ไม่มี prod ใน bucket นี้
  }
  // อัปเดต pointRadius ให้แสดงจุดสุดท้าย
  const lastNonNull = arr => { for(let i=arr.length-1;i>=0;i--) if(arr[i]!==null) return i; return -1; };
  // คำนวณ zones ตาม rangeH
  // zones: 24ชม./3วัน=time, 7วัน=ไม่มี, 6/12เดือน=ฤดูกาล
  const zones = (rangeH <= 72)
    ? makeTimeZones(labels, rangeH)
    : (rangeH > 720)
      ? makeSeasonZones(labels)
      : [];
  const zoneArr    = (typeof zones === 'object' && zones.zones) ? zones.zones    : zones;
  const seasonArr  = (typeof zones === 'object' && zones.seasons) ? zones.seasons : [];
  histTempChart.options.plugins.timeBg.zones   = zoneArr;
  histTempChart.options.plugins.timeBg.seasons = seasonArr;
  histHumiChart.options.plugins.timeBg.zones   = zoneArr;
  histHumiChart.options.plugins.timeBg.seasons = seasonArr;

  histTempChart.data.labels = labels;
  histTempChart.data.datasets[0].data = airData;
  histTempChart.data.datasets[1].data = prodData;
  histTempChart.data.datasets[2].data = humiData;
  histTempChart.update();

  histHumiChart.data.labels = labels;
  histHumiChart.data.datasets[0].data = humiData;
  histHumiChart.update();

  // อัปเดต WiFi + Rain charts — ใช้ bucket เดียวกับ labels
  // สร้าง bucket wifi/rain ที่สอดคล้องกับ labels ที่สร้างไว้แล้ว
  updateWifiRainCharts(rows, labels, rangeH);

  // วาด label จุดสุดท้าย
  setTimeout(() => {
    try {
      drawHistEndLabelDual(histTempChart, airData,  '#60a5fa', 'yT');
      drawHistEndLabelDual(histTempChart, prodData, '#fb923c', 'yT');
      drawHistEndLabelDual(histTempChart, humiData, '#34d399', 'yH');
    } catch(e) {}
  }, 80);
}

function drawHistEndLabel(chart, data, color) {
  try {
    const lastIdx = data.length-1 - [...data].reverse().findIndex(v=>v!==null);
    if (lastIdx < 0 || lastIdx >= data.length) return;
    const val = data[lastIdx];
    if (val === null) return;
    const ctx    = chart.ctx;
    const xScale = chart.scales && chart.scales.x;
    const yScale = chart.scales && chart.scales.y;
    if (!xScale || !yScale || typeof xScale.getPixelForValue !== 'function') return;
    const x = xScale.getPixelForValue(lastIdx);
    const y = yScale.getPixelForValue(val);
    ctx.save();
    ctx.fillStyle = color;
    ctx.font = 'bold 11px IBM Plex Mono, monospace';
    ctx.textAlign = 'right';
    ctx.fillText(val.toFixed(1), x - 6, y - 6);
    ctx.restore();
  } catch(e) {}
}



function updateWifiRainCharts(rows, labels, rangeH) {
  if (!histWifiChart || !histRainChart || !labels.length) return;

  // v2.6.5 Fix BUG1: Daily/Monthly ไม่มีข้อมูล wifi จริง → ซ่อน WiFi chart
  // แสดงเฉพาะ rangeH ≤ 168 (7 วัน) ที่มาจาก RawData เท่านั้น
  const wifiWrap = document.getElementById('wifi-chart-wrap');
  const rainGrid = document.getElementById('wifi-rain-grid');
  const showWifi = rangeH <= 168;
  if (wifiWrap) wifiWrap.style.display = showWifi ? '' : 'none';
  // ถ้าซ่อน wifi → rain chart ขยายเต็มแถว
  if (rainGrid) rainGrid.style.gridTemplateColumns = showWifi ? '1fr 1fr' : '1fr';

  const n = labels.length;
  const wifiSum = new Array(n).fill(0);
  const wifiCnt = new Array(n).fill(0);
  const rainMax = new Array(n).fill(null);

  // v2.6.5 Fix BUG2+BUG3: สร้าง labelMap จาก labels ที่ renderHistCharts สร้างไว้แล้ว
  // แล้วสร้าง key จาก r.ts ด้วย format เดียวกัน 100%
  const labelMap = {};
  labels.forEach((lbl, i) => { labelMap[lbl] = i; });

  rows.forEach(r => {
    const ts = r.ts;
    let key;

    if (rangeH <= 24) {
      // renderHistCharts ใช้ String(h).padStart(2,'0')+':00' เป็น bucket key
      // labels = Object.keys(buckets) = "00:00","01:00",...,"23:00"
      key = String(ts.getHours()).padStart(2,'0') + ':00';

    } else if (rangeH <= 72) {
      // renderHistCharts: toLocaleDateString(th-TH,{day,month:numeric}) + ' HH:00' (step 3h)
      const slotH = Math.floor(ts.getHours() / 3) * 3;
      key = ts.toLocaleDateString('th-TH', {day:'numeric', month:'numeric'})
          + ' ' + String(slotH).padStart(2,'0') + ':00';

    } else if (rangeH <= 168) {
      // renderHistCharts: toLocaleDateString(th-TH,{day,month:numeric}) + ' HH:00' (step 6h)
      const slotH = Math.floor(ts.getHours() / 6) * 6;
      key = ts.toLocaleDateString('th-TH', {day:'numeric', month:'numeric'})
          + ' ' + String(slotH).padStart(2,'0') + ':00';

    } else if (rangeH <= 720) {
      // renderHistCharts 30 วัน: toLocaleDateString(th-TH,{day:numeric,month:short})
      // ใช้ local time เหมือนกัน → key ตรงแน่นอน
      key = ts.toLocaleDateString('th-TH', {day:'numeric', month:'short'});

    } else {
      // renderHistCharts 6/12 เดือน: toLocaleDateString(th-TH,{month:short})
      key = ts.toLocaleDateString('th-TH', {month:'short'});
    }

    const i = labelMap[key];
    if (i === undefined) return;

    if (showWifi) {
      wifiSum[i] += (r.wifi || 0);
      wifiCnt[i]++;
    }
    if (rainMax[i] === null) rainMax[i] = r.rain;
    else if (r.rain > rainMax[i]) rainMax[i] = r.rain;
  });

  // WiFi chart (เฉพาะ ≤168h)
  if (showWifi) {
    const wifiData = wifiSum.map((s,i) => wifiCnt[i] > 0 ? +(s/wifiCnt[i]).toFixed(1) : null);
    histWifiChart.data.labels = labels;
    histWifiChart.data.datasets[0].data = wifiData;
    histWifiChart.options.plugins.timeBg.zones = makeTimeZones(labels, rangeH);
    histWifiChart.update('none');
  }

  // Rain chart (ทุก range)
  histRainChart.data.labels = labels;
  histRainChart.data.datasets[0].data = rainMax;
  histRainChart.options.plugins.timeBg.zones =
    (rangeH <= 168) ? makeTimeZones(labels, rangeH)
    : (rangeH > 720) ? (makeSeasonZones(labels).zones || []) : [];
  histRainChart.update('none');
}


