// โหลดข้อมูล RT ตามวันที่เลือก
async function loadRtByDate() {
  const picker = document.getElementById('rt-date-picker');
  if (!picker || !picker.value) { showToast('กรุณาเลือกวันที่','warn'); return; }
  const dateStr = picker.value; // YYYY-MM-DD
  const today   = new Date().toISOString().slice(0,10);
  const isToday = dateStr === today;

  const titleEl  = document.getElementById('rt-chart-title');
  const todayBtn = document.getElementById('btn-rt-today');

  if (isToday) {
    if (titleEl) titleEl.textContent = 'ปัจจุบัน';
    if (todayBtn) { todayBtn.style.color = 'var(--air)'; todayBtn.style.borderColor = 'var(--air)'; }
    initRtChart();
    await loadTodayIntoRtChart();
    return;
  }

  if (titleEl) titleEl.textContent = 'ข้อมูล ' + dateStr;
  if (todayBtn) { todayBtn.style.color = 'var(--muted)'; todayBtn.style.borderColor = 'var(--border)'; }

  if (!CFG.sheetsUrl || CFG.sheetsUrl.includes('YOUR_')) {
    showToast('ยังไม่ตั้งค่า sheetsUrl ใน CFG','error');
    return;
  }
  logMqtt('[Date] กำลังโหลด ' + dateStr + '...', '#60a5fa');

  logMqtt('[Date] กำลังโหลดข้อมูล ' + dateStr + '...', '#60a5fa');
  try {
    const res  = await fetch(CFG.sheetsUrl);
    const text = await res.text();
    const lines = text.trim().split('\n');
    if (lines.length < 2) return;
    const hdrs  = lines[0].split(',').map(h => h.replace(/^"|"$/g,'').trim().toLowerCase());
    const iTime = hdrs.indexOf('time');
    const iAir  = hdrs.indexOf('temp_air');
    const iHumi = hdrs.indexOf('humidity');
    const iProd = hdrs.indexOf('temp_product');
    if (iTime < 0) return;
    let count = 0;
    for (let i=1; i<lines.length; i++) {
      const cols = lines[i].split(',').map(c => c.replace(/^"|"$/g,'').trim());
      const ts   = cols[iTime];
      if (!ts || !ts.startsWith(dateStr)) continue;
      const dt = parseTimestamp(ts);
      if (!dt) continue;
      const slot = slotIndex(dt);
      const air  = parseFloat(cols[iAir]);
      const humi = parseFloat(cols[iHumi]);
      const prod = parseFloat(cols[iProd]);
      if (!isNaN(air))  rtAllData.air[slot]  = air;
      if (!isNaN(humi)) rtAllData.humi[slot] = humi;
      if (!isNaN(prod)) rtAllData.prod[slot] = prod;
      count++;
    }
    if (count > 0 && rtChart) {
      rtChart.data.datasets[0].data = rtAllData.air;
      rtChart.data.datasets[1].data = rtAllData.humi;
      rtChart.data.datasets[2].data = rtAllData.prod;
      rtChart.options.plugins.timeBg.zones = makeTimeZones(buildRtLabels(), 24);
      rtChart._zonesSet = true;
      rtChart.update();

      logMqtt('[Date] โหลด ' + count + ' จุด วันที่ ' + dateStr, '#34d399');
    } else {
      logMqtt('[Date] ไม่มีข้อมูลวันที่ ' + dateStr + ' ใน Sheets', '#fbbf24');
    }
  } catch(e) {
    logMqtt('[Date] โหลดไม่สำเร็จ: ' + e.message, '#f87171');
  }
}

