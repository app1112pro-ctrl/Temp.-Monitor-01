// ── helpers ──────────────────────────────
function downloadFile(filename, text, mime) {
  const blob = new Blob(['﻿'+text], { type: mime }); // BOM for Excel Thai
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function dateStamp() {
  const d = new Date();
  return d.getFullYear()
    + String(d.getMonth()+1).padStart(2,'0')
    + String(d.getDate()).padStart(2,'0')
    + '_' + String(d.getHours()).padStart(2,'0')
    + String(d.getMinutes()).padStart(2,'0');
}

function makePDF(title, headers, rows, filename) {
  try {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: rows.length > 20 ? 'landscape' : 'portrait' });
    // title
    doc.setFontSize(14);
    doc.setFont('helvetica','bold');
    doc.text(title, 14, 16);
    doc.setFontSize(9);
    doc.setFont('helvetica','normal');
    doc.text('Generated: ' + new Date().toLocaleString('th-TH'), 14, 22);
    // table
    doc.autoTable({
      head: [headers],
      body: rows,
      startY: 27,
      styles: { fontSize: 8, cellPadding: 2 },
      headStyles: { fillColor: [14, 32, 53], textColor: [200, 216, 240], fontStyle: 'bold' },
      alternateRowStyles: { fillColor: [240, 244, 248] },
      margin: { left: 14, right: 14 },
    });
    doc.save(filename);
  } catch(e) {
    showToast('PDF error: ' + e.message, 'error');
  }
}

// ── 1. Export Realtime CSV (ข้อมูลวันนี้) ───────────────────────────────
function exportRealtimeCSV() {
  const labels = buildRtLabels();
  const rows   = [];
  rows.push(['เวลา','T.อากาศ (°C)','ความชื้น (%RH)','T.ผลิตภัณฑ์ (°C)'].join(','));
  labels.forEach((lbl, i) => {
    const air  = rtAllData.air[i];
    const humi = rtAllData.humi[i];
    const prod = rtAllData.prod[i];
    if (air !== null || humi !== null || prod !== null) {
      rows.push([
        lbl,
        air  !== null ? air.toFixed(1)  : '',
        humi !== null ? humi.toFixed(1) : '',
        prod !== null ? prod.toFixed(1) : '',
      ].join(','));
    }
  });
  if (rows.length <= 1) { showToast('ไม่มีข้อมูลวันนี้','info'); return; }
  downloadFile('Realtime_' + dateStamp() + '.csv', rows.join('\n'), 'text/csv');
  logMqtt('[Export] Realtime CSV ' + (rows.length-1) + ' rows', '#34d399');
}

// ── 2. Export History CSV (ข้อมูลสะสมจาก Sheets) ───────────────────────
async function exportHistoryCSV() {
  const btn = document.querySelector('.export-btn.csv[onclick="exportHistoryCSV()"]');
  if (btn) { btn.textContent = 'กำลังโหลด...'; btn.disabled = true; }
  try {
    const res  = await fetch(CFG.sheetsUrl);
    const text = await res.text();
    const lines = text.trim().split('\n');
    const cutoff = Date.now() - histRange * 3600000;
    const hdrs = lines[0];
    const dataRows = lines.slice(1).filter(line => {
      const ts = new Date(line.split(',')[0].replace(/^"|"$/g,'').replace(' ','T'));
      return !isNaN(ts) && ts >= cutoff;
    });
    const csv = [hdrs, ...dataRows].join('\n');
    const rangeLabel = histRange<=24?'24h':histRange<=72?'3d':histRange<=168?'7d':histRange<=720?'30d':histRange<=4380?'6m':'12m';
    downloadFile('RawData_' + rangeLabel + '_' + dateStamp() + '.csv', csv, 'text/csv');
    logMqtt('[Export] History CSV ' + dataRows.length + ' rows', '#34d399');
  } catch(e) {
    showToast('Export ไม่สำเร็จ: ' + e.message, 'error');
  }
  if (btn) { btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="12" y1="11" x2="12" y2="17"/><polyline points="9,14 12,17 15,14"/></svg>CSV'; btn.disabled = false; }
}

