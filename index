async function loadTodayIntoRtChart(retryCount = 0) {
  const MAX_RETRY = 3;
  const RETRY_DELAY_MS = 3000;

  if (!CFG.sheetsUrl || CFG.sheetsUrl.includes('YOUR_')) return;
  try {
    const res   = await fetch(CFG.sheetsUrl + '&t=' + Date.now());
    const text  = await res.text();
    const lines = text.trim().split('\n');
    if (lines.length < 2) {
      logMqtt('[Today] CSV ว่างเปล่า', '#fbbf24');
      return;
    }

    const headers = lines[0].split(',').map(h => h.replace(/^"|"$/g,'').trim().toLowerCase());
    const col   = name => headers.indexOf(name);
    const iTime = col('time');
    const iAir  = col('temp_air');
    const iHumi = col('humidity');
    const iProd = col('temp_product');
    if (iTime < 0) { logMqtt('[Today] ไม่พบ column time', '#f87171'); return; }

    const now      = new Date();
    const todayStr = now.getFullYear() + '-'
      + String(now.getMonth()+1).padStart(2,'0') + '-'
      + String(now.getDate()).padStart(2,'0');

    // reset data ก่อนเติม
    rtAllData.air  = Array(144).fill(null);
    rtAllData.humi = Array(144).fill(null);
    rtAllData.prod = Array(144).fill(null);

    let count = 0;
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line) continue;
      const cols  = line.split(',').map(c => c.replace(/^"|"$/g,'').trim());
      const tsStr = cols[iTime];
      if (!tsStr || tsStr.slice(0,10) !== todayStr) continue;
      const dt = parseTimestamp(tsStr);
      if (!dt) continue;
      const slot = dt.getHours() * 6 + Math.floor(dt.getMinutes() / 10);
      if (slot < 0 || slot > 143) continue;
      const air  = parseFloat(cols[iAir]);
      const humi = parseFloat(cols[iHumi]);
      const prod = parseFloat(cols[iProd]);
      if (!isNaN(air))  rtAllData.air[slot]  = air;
      if (!isNaN(humi)) rtAllData.humi[slot] = humi;
      if (!isNaN(prod)) rtAllData.prod[slot] = prod;
      count++;
    }

    if (count === 0) {
      logMqtt('[Today] ไม่พบข้อมูล ' + todayStr, '#fbbf24');
      return;
    }

    logMqtt('[Today] โหลดสำเร็จ ' + count + ' จุด (' + todayStr + ')', '#34d399');
    // v2.6.2: อัปเดต metric cards จากข้อมูลล่าสุดทันที
    updateLatestStateFromSheets();
    if (!rtChart) return;
    rtChart.data.datasets[0].data = rtAllData.air;
    rtChart.data.datasets[1].data = rtAllData.humi;
    rtChart.data.datasets[2].data = rtAllData.prod;
    rtChart.options.plugins.timeBg.zones = makeTimeZones(buildRtLabels(), 24);
    rtChart._zonesSet = true;
    rtChart.update('none');

  } catch(e) {
    if (retryCount < MAX_RETRY) {
      const next = retryCount + 1;
      logMqtt('[Today] fetch ล้มเหลว ลองใหม่ครั้งที่ ' + next + '/' + MAX_RETRY + '...', '#fbbf24');
      setTimeout(() => loadTodayIntoRtChart(next), RETRY_DELAY_MS);
    } else {
      logMqtt('[Today] ล้มเหลว ' + MAX_RETRY + ' ครั้ง: ' + e.message, '#f87171');
    }
  }
}



