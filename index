function sendCmd(cmd) {
  publish({ cmd });
}

function setProgram(prog) {
  publish({ cmd: 'set_program', value: prog });
  if (prog === 'CUSTOM') {
    $('custom-inputs').style.display = 'block';
  } else {
    $('custom-inputs').style.display = 'none';
  }
}

function sendCustom() {
  const h = parseFloat($('custom-humi').value);
  const t = parseFloat($('custom-temp').value);
  if (isNaN(h) || h < 10 || h > 90) { showToast('ความชื้น 10–90%','warn'); return; }
  if (isNaN(t) || t < 30 || t > 100) { showToast('อุณหภูมิ 30–100°C','warn'); return; }
  publish({ cmd: 'set_custom_humi', value: h });
  setTimeout(() => publish({ cmd: 'set_custom_max_temp', value: t }), 300);
}

function sendNightTime() {
  const ns = $('night-start').value;
  const ne = $('night-end').value;
  if (!ns || !ne) { showToast('กรุณากรอกเวลา','warn'); return; }
  publish({ cmd: 'set_night_start', value: ns });
  setTimeout(() => publish({ cmd: 'set_night_end', value: ne }), 300);
}

